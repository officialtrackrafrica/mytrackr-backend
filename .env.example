
PORT=3000
NODE_ENV=development
# Comma-separated browser origins permitted to send credentialed requests.
CORS_ORIGINS=http://localhost:5173,https://mytrackr-frontend.vercel.app,https://dashboard.mytrackrservices.com
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

DATABASE_URL=postgresql://user:password@localhost:5432/mytrackr


JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

REDIS_URL=redis://localhost:6379

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
GOOGLE_REDIRECT_URL=https://dashboard.mytrackrservices.com/signup

MONO_SECRET_KEY=your_mono_secret_key
MONO_API_URL=https://api.withmono.com

SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@mytrackr.app


OCR_SERVICE_URL=http://localhost:8000
OCR_TEXT_HANDLING_FLAG=--force-ocr
# External AI provider (for example, Groq or Google AI Studio). Leave the
# values blank to disable AI-assisted statement parsing and categorization.
STATEMENT_AI_BASE_URL=
STATEMENT_AI_MODEL=
STATEMENT_AI_API_KEY=
STATEMENT_AI_TEMPERATURE=0
STATEMENT_AI_TOP_P=0.1
STATEMENT_AI_TIMEOUT_MS=120000
STATEMENT_AI_QUEUE_ENABLED=true
STATEMENT_AI_RPM_LIMIT=15
STATEMENT_AI_MAX_CONCURRENT=1
STATEMENT_AI_QUEUE_POLL_INTERVAL_MS=1000

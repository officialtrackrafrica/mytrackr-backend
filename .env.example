STATEMENT_AI_API_KEY=ollama
STATEMENT_AI_TEMPERATURE=0
STATEMENT_AI_TOP_P=0.1
STATEMENT_AI_TIMEOUT_MS=120000
STATEMENT_AI_QUEUE_ENABLED=true
STATEMENT_AI_RPM_LIMIT=15
STATEMENT_AI_MAX_CONCURRENT=1
STATEMENT_AI_QUEUE_POLL_INTERVAL_MS=1000
OLLAMA_MODEL=phi3:mini

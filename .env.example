SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@mytrackr.app


OCR_SERVICE_URL=http://localhost:8000
OCR_TEXT_HANDLING_FLAG=--force-ocr
STATEMENT_AI_BASE_URL=http://ollama:11434/v1

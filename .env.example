# App Environment Variables

# ─── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/mytrackr
# SSL (set to 'require' in production)
# DATABASE_SSL=require

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# ─── Redis ─────────────────────────────────────────────────────────────────────
# Option A: full URL
REDIS_URL=redis://localhost:6379

# Option B: host + port (used when REDIS_URL is not set)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ─── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ─── Mono ──────────────────────────────────────────────────────────────────────
MONO_SECRET_KEY=your_mono_secret_key
MONO_API_URL=https://api.withmono.com

# ─── SMTP / Email ──────────────────────────────────────────────────────────────
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@mytrackr.app

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=mytrackr

# JWT Secrets (generate secure random values for production)
JWT_ACCESS_SECRET=your_access_secret_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_change_in_production

# Encryption
ENCRYPTION_PASSWORD=your_encryption_password_change_in_production

# WebAuthn
WEBAUTHN_RP_NAME=MyTrackr
WEBAUTHN_RP_ID=localhost
WEBAUTHN_EXPECTED_ORIGIN=http://localhost:3000

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379

# App
PORT=3000
NODE_ENV=development

# Mono integration
MONO_SECRET_KEY=your_mono_secret_key_here
MONO_WEBHOOK_SECRET=your_mono_webhook_secret_here

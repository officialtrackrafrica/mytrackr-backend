{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "assets": [
      {
        "include": "email/templates/**/*",
        "watchAssets": true
      },
      {
        "include": "proto/**/*.proto",
        "watchAssets": true
      }
    ],
    "deleteOutDir": true
  }
}

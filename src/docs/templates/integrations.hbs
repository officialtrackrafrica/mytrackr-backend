<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{title}}</title>
    <meta name="description" content="{{description}}" />
    <style>
      :root {
        --bg: #f4efe6;
        --paper: #fffaf2;
        --ink: #182028;
        --muted: #5f6a72;
        --line: #d9cdbd;
        --accent: #0d6b5f;
        --accent-2: #d56f3e;
        --code: #132128;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Georgia, "Times New Roman", serif;
        color: var(--ink);
        background:
          radial-gradient(circle at top left, rgba(213, 111, 62, 0.16), transparent 30%),
          radial-gradient(circle at top right, rgba(13, 107, 95, 0.16), transparent 26%),
          linear-gradient(180deg, #f7f0e3 0%, var(--bg) 100%);
      }
      a { color: var(--accent); }
      .wrap {
        width: min(1180px, calc(100% - 32px));
        margin: 0 auto;
        padding: 32px 0 64px;
      }
      .hero {
        background: rgba(255, 250, 242, 0.84);
        border: 1px solid var(--line);
        border-radius: 28px;
        padding: 32px;
        box-shadow: 0 20px 40px rgba(24, 32, 40, 0.08);
      }
      .eyebrow {
        font: 600 12px/1.2 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--accent-2);
      }
      h1, h2, h3 {
        margin: 0 0 12px;
        line-height: 1.05;
      }
      h1 { font-size: clamp(2.4rem, 5vw, 4.7rem); max-width: 12ch; }
      h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); margin-top: 28px; }
      h3 { font-size: 1.15rem; }
      p, li {
        font: 400 1rem/1.65 "Segoe UI", Arial, sans-serif;
        color: var(--muted);
      }
      .hero-grid,
      .grid {
        display: grid;
        gap: 18px;
      }
      .hero-grid {
        grid-template-columns: 2fr 1fr;
        align-items: start;
      }
      .links,
      .card,
      .endpoint,
      .snippet {
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 22px;
      }
      .links,
      .card,
      .endpoint,
      .snippet {
        padding: 20px;
      }
      .link-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .link-pill {
        display: block;
        padding: 12px 14px;
        border-radius: 14px;
        background: #f1eadf;
        text-decoration: none;
        font: 600 0.96rem/1.3 "Segoe UI", Arial, sans-serif;
      }
      .section {
        margin-top: 26px;
      }
      .grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .endpoint-grid {
        display: grid;
        gap: 16px;
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .badge {
        display: inline-block;
        padding: 6px 10px;
        border-radius: 999px;
        background: #e8f0ee;
        color: var(--accent);
        font: 700 0.76rem/1 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .path {
        margin-top: 10px;
        font: 700 1rem/1.4 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        word-break: break-word;
      }
      .meta {
        margin: 8px 0 0;
        font: 600 0.9rem/1.4 "Segoe UI", Arial, sans-serif;
        color: var(--ink);
      }
      pre {
        margin: 12px 0 0;
        padding: 16px;
        overflow: auto;
        border-radius: 16px;
        background: var(--code);
        color: #f5f7f7;
        font: 0.88rem/1.55 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      }
      code {
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      }
      ul {
        padding-left: 20px;
        margin: 10px 0 0;
      }
      .mini {
        font-size: 0.92rem;
      }
      @media (max-width: 900px) {
        .hero-grid,
        .grid,
        .endpoint-grid {
          grid-template-columns: 1fr;
        }
        .wrap {
          width: min(100% - 20px, 1180px);
        }
        .hero {
          padding: 24px;
        }
      }
    </style>
  </head>
  <body>
    <main class="wrap">
      <section class="hero">
        <div class="hero-grid">
          <div>
            <div class="eyebrow">Developer Guide</div>
            <h1>{{title}}</h1>
            <p>
              Build React, WordPress, or custom website integrations against MyTrackr's current server-side endpoints.
              This page covers the production flow after the subscription changes: integrations are enabled by the app subscription,
              not by a separate integration checkout.
            </p>
          </div>
          <aside class="links">
            <h3>Reference</h3>
            <div class="link-list">
              <a class="link-pill" href="{{swaggerUrl}}">Open Swagger UI</a>
              <a class="link-pill" href="{{swaggerJsonUrl}}">Open Swagger JSON</a>
            </div>
            <p class="mini">
              Base URL: <code>{{baseUrl}}</code>
            </p>
          </aside>
        </div>
      </section>

      <section class="section">
        <h2>Prerequisites</h2>
        <div class="grid">
          <div class="card">
            <h3>Access rules</h3>
            <ul>
              {{#each prerequisites}}
              <li>{{this}}</li>
              {{/each}}
            </ul>
          </div>
          <div class="card">
            <h3>Supported event types</h3>
            <ul>
              {{#each eventTypes}}
              <li><code>{{this}}</code></li>
              {{/each}}
            </ul>
          </div>
        </div>
      </section>

      <section class="section">
        <h2>Integration Flow</h2>
        <div class="grid">
          {{#each steps}}
          <article class="card">
            <h3>{{title}}</h3>
            <p>{{body}}</p>
          </article>
          {{/each}}
        </div>
      </section>

      {{#each endpointGroups}}
      <section class="section">
        <h2>{{title}} Endpoints</h2>
        <div class="endpoint-grid">
          {{#each endpoints}}
          <article class="endpoint">
            <span class="badge">{{method}}</span>
            <div class="path">{{path}}</div>
            <p class="meta">Auth: {{auth}}</p>
            <p>{{summary}}</p>
            {{#if notes}}
            <ul>
              {{#each notes}}
              <li>{{this}}</li>
              {{/each}}
            </ul>
            {{/if}}
            {{#if requestExample}}
            <h3>Request</h3>
            <pre><code>{{requestExample}}</code></pre>
            {{/if}}
            {{#if responseExample}}
            <h3>Response</h3>
            <pre><code>{{responseExample}}</code></pre>
            {{/if}}
          </article>
          {{/each}}
        </div>
      </section>
      {{/each}}

      <section class="section">
        <h2>Code Examples</h2>
        <div class="grid">
          {{#each codeExamples}}
          <article class="snippet">
            <h3>{{title}}</h3>
            <p class="mini">Language: <code>{{language}}</code></p>
            <pre><code>{{code}}</code></pre>
          </article>
          {{/each}}
        </div>
      </section>
    </main>
  </body>
</html>
